{
  "name": "@agentcompose/research-agent",
  "version": "0.1.0",
  "description": "A configurable, spec-compliant research worker for AgentCompose: an adaptive plan → search → read → reflect → synthesize loop over a pluggable search backend, producing a cited report.",
  "license": "Apache-2.0",
  "homepage": "https://agentcompose.dev",
  "repository": { "type": "git", "url": "git+https://github.com/agentcompose/research-agent.git" },
  "type": "module",
  "engines": { "node": ">=18.19" },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "node --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentcompose/sdk": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  }
}
